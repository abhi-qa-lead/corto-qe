    {
      "name": "GetBookingIds",
      "event": [
        {
          "script": {
            "type": "text/javascript",
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Response is a non-empty array of booking ids\", function () {",
              "    pm.expect(jsonData).to.be.an(\"array\").that.is.not.empty;",
              "    jsonData.forEach(function (item) {",
              "        pm.expect(item).to.have.all.keys(\"bookingid\");",
              "        pm.expect(item.bookingid).to.be.a(\"number\").and.to.be.above(0);",
              "    });",
              "});",
              "",
              "pm.test(\"Booking ids are unique in this response\", function () {",
              "    const bookingIds = jsonData.map(function (item) { return item.bookingid; });",
              "    pm.expect(new Set(bookingIds).size).to.eql(bookingIds.length);",
              "});"
            ]
          },
          "listen": "test"
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking"
          ]
        },
        "description": "Returns all booking ids currently available in the API."
      },
      "response": []
    },
    {
      "name": "CreateBooking",
      "event": [
        {
          "script": {
            "exec": [
              "const firstname = pm.variables.replaceIn('{{$randomFirstName}}');",
              "const lastname = pm.variables.replaceIn('{{$randomLastName}}');",
              "const totalprice = Math.floor(Math.random() * 1000) + 100;",
              "const depositpaid = Math.random() > 0.5;",
              "const checkin = new Date(pm.variables.replaceIn('{{$randomDatePast}}'));",
              "const checkout = new Date(pm.variables.replaceIn('{{$randomDateFuture}}'));",
              "const additionalneeds = pm.variables.replaceIn('{{$randomWord}}');",
              "const formatDate = (date) => date.toISOString().split('T')[0];",
              "",
              "pm.variables.set('firstname', firstname);",
              "pm.variables.set('lastname', lastname);",
              "pm.variables.set('totalprice', totalprice);",
              "pm.variables.set('depositpaid', depositpaid);",
              "pm.variables.set('checkin', formatDate(checkin));",
              "pm.variables.set('checkout', formatDate(checkout));",
              "pm.variables.set('additionalneeds', additionalneeds);"
            ],
            "type": "text/javascript"
          },
          "listen": "prerequest"
        },
        {
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "const expectedBooking = {",
              "    firstname: pm.variables.get('firstname'),",
              "    lastname: pm.variables.get('lastname'),",
              "    totalprice: Number(pm.variables.get('totalprice')),",
              "    depositpaid: String(pm.variables.get('depositpaid')) === 'true',",
              "    bookingdates: {",
              "        checkin: pm.variables.get('checkin'),",
              "        checkout: pm.variables.get('checkout')",
              "    },",
              "    additionalneeds: pm.variables.get('additionalneeds')",
              "};",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"CreateBooking response has expected structure\", function () {",
              "    pm.expect(jsonData).to.have.all.keys('bookingid', 'booking');",
              "    pm.expect(jsonData.booking).to.have.all.keys('firstname', 'lastname', 'totalprice', 'depositpaid', 'bookingdates', 'additionalneeds');",
              "    pm.expect(jsonData.booking.bookingdates).to.have.all.keys('checkin', 'checkout');",
              "    pm.expect(jsonData.bookingid).to.be.a('number').and.to.be.above(0);",
              "});",
              "",
              "pm.test(\"Created booking matches the submitted payload\", function () {",
              "    pm.expect(jsonData.booking).to.deep.equal(expectedBooking);",
              "});",
              "",
              "pm.collectionVariables.set('bookingid', String(jsonData.bookingid));",
              "pm.collectionVariables.set('createBookingResponse', JSON.stringify(jsonData.booking));"
            ],
            "type": "text/javascript"
          },
          "listen": "test"
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "value": "application/json",
            "key": "Content-Type"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"{{firstname}}\",\n    \"lastname\" : \"{{lastname}}\",\n    \"totalprice\" : {{totalprice}},\n    \"depositpaid\" : {{depositpaid}},\n    \"bookingdates\" : {\n        \"checkin\" : \"{{checkin}}\",\n        \"checkout\" : \"{{checkout}}\"\n    },\n    \"additionalneeds\" : \"{{additionalneeds}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking"
          ]
        },
        "description": "Creates a new booking with dynamic data and stores the created booking id for downstream requests."
      },
      "response": []
    },
    {
      "name": "GetBooking",
      "event": [
        {
          "script": {
            "type": "text/javascript",
            "exec": [
              "const expectedBooking = JSON.parse(pm.collectionVariables.get('createBookingResponse'));",
              "const actualBooking = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"GetBooking matches the created booking\", function () {",
              "    pm.expect(actualBooking).to.deep.equal(expectedBooking);",
              "});",
              "",
              "pm.test(\"GetBooking response shape is valid\", function () {",
              "    pm.expect(actualBooking).to.have.all.keys('firstname', 'lastname', 'totalprice', 'depositpaid', 'bookingdates', 'additionalneeds');",
              "    pm.expect(actualBooking.bookingdates).to.have.all.keys('checkin', 'checkout');",
              "});"
            ]
          },
          "listen": "test"
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{bookingid}}",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking",
            "{{bookingid}}"
          ]
        },
        "description": "Fetches the booking created earlier in the run and validates it matches the stored booking payload."
      },
      "response": []
    },
    {
      "name": "UpdateBooking",
      "event": [
        {
          "script": {
            "type": "text/javascript",
            "exec": [
              "const updatedFirstname = pm.variables.replaceIn('{{$randomFirstName}}');",
              "const updatedLastname = pm.variables.replaceIn('{{$randomLastName}}');",
              "const updatedTotalprice = Math.floor(Math.random() * 1000) + 1000;",
              "const updatedDepositpaid = Math.random() > 0.5;",
              "const updatedCheckin = new Date(pm.variables.replaceIn('{{$randomDateRecent}}'));",
              "const updatedCheckout = new Date(pm.variables.replaceIn('{{$randomDateFuture}}'));",
              "const updatedAdditionalneeds = pm.variables.replaceIn('{{$randomJobTitle}}');",
              "const formatDate = (date) => date.toISOString().split('T')[0];",
              "",
              "pm.variables.set('updatedFirstname', updatedFirstname);",
              "pm.variables.set('updatedLastname', updatedLastname);",
              "pm.variables.set('updatedTotalprice', updatedTotalprice);",
              "pm.variables.set('updatedDepositpaid', updatedDepositpaid);",
              "pm.variables.set('updatedCheckin', formatDate(updatedCheckin));",
              "pm.variables.set('updatedCheckout', formatDate(updatedCheckout));",
              "pm.variables.set('updatedAdditionalneeds', updatedAdditionalneeds);"
            ]
          },
          "listen": "prerequest"
        },
        {
          "script": {
            "type": "text/javascript",
            "exec": [
              "const jsonData = pm.response.json();",
              "const expectedBooking = {",
              "    firstname: pm.variables.get('updatedFirstname'),",
              "    lastname: pm.variables.get('updatedLastname'),",
              "    totalprice: Number(pm.variables.get('updatedTotalprice')),",
              "    depositpaid: String(pm.variables.get('updatedDepositpaid')) === 'true',",
              "    bookingdates: {",
              "        checkin: pm.variables.get('updatedCheckin'),",
              "        checkout: pm.variables.get('updatedCheckout')",
              "    },",
              "    additionalneeds: pm.variables.get('updatedAdditionalneeds')",
              "};",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"UpdateBooking replaces the booking payload\", function () {",
              "    pm.expect(jsonData).to.deep.equal(expectedBooking);",
              "});",
              "",
              "pm.collectionVariables.set('updatedBookingResponse', JSON.stringify(jsonData));"
            ]
          },
          "listen": "test"
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "value": "application/json",
            "key": "Content-Type"
          },
          {
            "value": "application/json",
            "key": "Accept"
          },
          {
            "value": "token={{token}}",
            "key": "Cookie"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"{{updatedFirstname}}\",\n    \"lastname\" : \"{{updatedLastname}}\",\n    \"totalprice\" : {{updatedTotalprice}},\n    \"depositpaid\" : {{updatedDepositpaid}},\n    \"bookingdates\" : {\n        \"checkin\" : \"{{updatedCheckin}}\",\n        \"checkout\" : \"{{updatedCheckout}}\"\n    },\n    \"additionalneeds\" : \"{{updatedAdditionalneeds}}\"\n}"
        },
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{bookingid}}",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking",
            "{{bookingid}}"
          ]
        },
        "description": "Fully updates the booking created earlier in the run using the auth token from CreateToken."
      },
      "response": []
    },
    {
      "name": "PartialUpdateBooking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set('patchFirstname', pm.variables.replaceIn('{{$randomFirstName}}'));",
              "pm.variables.set('patchAdditionalneeds', pm.variables.replaceIn('{{$randomProductName}}'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const previousBooking = JSON.parse(pm.collectionVariables.get('updatedBookingResponse'));",
              "const jsonData = pm.response.json();",
              "const expectedBooking = Object.assign({}, previousBooking, {",
              "    firstname: pm.variables.get('patchFirstname'),",
              "    additionalneeds: pm.variables.get('patchAdditionalneeds')",
              "});",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"PartialUpdateBooking updates only the requested fields\", function () {",
              "    pm.expect(jsonData).to.deep.equal(expectedBooking);",
              "});",
              "",
              "pm.collectionVariables.set('patchedBookingResponse', JSON.stringify(jsonData));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"{{patchFirstname}}\",\n    \"additionalneeds\" : \"{{patchAdditionalneeds}}\"\n}"
        },
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{bookingid}}",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking",
            "{{bookingid}}"
          ]
        },
        "description": "Partially updates selected fields on the booking and verifies untouched fields remain intact."
      },
      "response": []
    },
    {
      "name": "DeleteBooking",
      "event": [
        {
          "script": {
            "type": "text/javascript",
            "exec": [
              "const bookingId = pm.collectionVariables.get('bookingid');",
              "const responseBody = pm.response.text();",
              "",
              "pm.test(\"DeleteBooking returns success status\", function () {",
              "    pm.expect(pm.response.code).to.eql(201);",
              "});",
              "",
              "pm.test(\"DeleteBooking response body is acceptable\", function () {",
              "    pm.expect(['', 'Created']).to.include(responseBody);",
              "});",
              "",
              "pm.test(\"Deleted booking is no longer retrievable\", function (done) {",
              "    pm.sendRequest({",
              "        url: `https://restful-booker.herokuapp.com/booking/${bookingId}`,",
              "        method: 'GET'",
              "    }, function (err, res) {",
              "        pm.expect(err).to.eql(null);",
              "        pm.expect(res.code).to.eql(404);",
              "        done();",
              "    });",
              "});"
            ]
          },
          "listen": "test"
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{bookingid}}",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking",
            "{{bookingid}}"
          ]
        },
        "description": "Deletes the booking created earlier in the run and verifies it is no longer retrievable."
      },
      "response": []
    },
