      "Bash(npx prettier:*)",
      "Bash(claude mcp:*)",
      "Bash(npm search:*)",
      "Bash(npm info:*)",
      "Bash(mv src/api/clients/request.client.ts src/helpers/api.client.ts)",
      "Bash(mv src/reporters/spec.reporter.ts src/helpers/spec.reporter.ts)",
