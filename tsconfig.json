{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ui/*": ["src/ui/*"],
      "@api/*": ["src/api/*"],
      "@fixtures": ["src/ui/fixtures"]
    }
  }
}
